@model IEnumerable<PaloGames.Models.Evento>

@{
    ViewData["Title"] = "Agenda Universitaria";
}

<div class="container mt-4">
    <h1 class="text-center mb-4 fw-bold">Agenda Universitaria y Juvenil</h1>

    <form asp-controller="Eventos" asp-action="Index" method="get" class="mb-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="input-group input-group-lg shadow-sm">
                    <span class="input-group-text bg-dark text-white border-dark">
                        <i class="bi bi-funnel-fill"></i> Filtrar:
                    </span>
                    <select name="tipoEvento" class="form-select border-dark">
                        <option value="">Todos los eventos...</option>
                        <option value="Eventos Juveniles" selected="@(ViewData["FiltroActual"]?.ToString() == "Eventos Juveniles")">Eventos Juveniles</option>
                        <option value="Culturales" selected="@(ViewData["FiltroActual"]?.ToString() == "Culturales")">Culturales</option>
                        <option value="Conciertos" selected="@(ViewData["FiltroActual"]?.ToString() == "Conciertos")">Conciertos</option>
                        <option value="Ferias" selected="@(ViewData["FiltroActual"]?.ToString() == "Ferias")">Ferias</option>
                        <option value="Hackatons" selected="@(ViewData["FiltroActual"]?.ToString() == "Hackatons")">Hackatons</option>
                    </select>
                    <button class="btn btn-dark px-4" type="submit">Buscar</button>
                </div>
            </div>
        </div>
    </form>

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12 text-center mt-5">
                <h4 class="text-muted">No se encontraron eventos para esta categoría.</h4>
            </div>
        }
        else
        {
            @foreach (var item in Model) {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 bg-light">
                        <img src="@item.ImagenUrl" class="card-img-top rounded-top" alt="@item.Titulo" style="height: 220px; object-fit: cover;">
                        <div class="card-body">
                            <span class="badge bg-primary mb-2">@item.Categoria</span>
                            <h5 class="card-title fw-bold">@item.Titulo</h5>
                            <p class="card-text text-secondary" style="font-size: 0.9rem;">
                                @(item.Descripcion.Length > 90 ? item.Descripcion.Substring(0, 90) + "..." : item.Descripcion)
                            </p>
                            <hr>
                            <ul class="list-unstyled mb-0" style="font-size: 0.9rem;">
                                <li class="mb-1"><strong>📅 Fecha:</strong> @item.Fecha.ToString("dd/MM/yyyy HH:mm")</li>
                                <li class="mb-1"><strong>📍 Lugar:</strong> @item.Ubicacion</li>
                                <li><strong>💰 Costo:</strong> @(item.Costo == 0 ? "¡Gratis!" : $"S/ {item.Costo}")</li>
                            </ul>
                        </div>
                        <div class="card-footer bg-transparent border-top-0 d-flex gap-2 pb-3">
                            <a asp-action="Detalles" asp-route-id="@item.Id" class="btn btn-outline-dark w-50 fw-bold">Detalles</a>
                            <a href="#" class="btn btn-success w-50 fw-bold">¡Me apunto!</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>