<!DOCTYPE html>
@using Microsoft.AspNetCore.Http
@using PaloGames.Infrastructure
@using PaloGames.Models
@inject IHttpContextAccessor HttpContextAccessor
<html>
<head>
    <meta charset="utf-8" />
    <title>PALOEVENTS</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>

    <nav class="navbar">
        <a href="/Home" style="text-decoration: none;">
            <div class="logo">
                <span>PALOEVENTS</span>
            </div>
        </a>

        <ul class="menu">
            <li><a href="/Home">Inicio</a></li>
            <li><a class="nav-link text-dark" asp-area="" asp-controller="Eventos" asp-action="Index">Eventos</a></li>
            <li><a href="#">Blog</a></li>
            <li><a href="#">Nosotros</a></li>
            <li><a href="#">Contacto</a></li>
        </ul>

        <div class="actions">
            @{
                // Lógica de la Funcionalidad 2: Mi Agenda
                var agenda = HttpContextAccessor.HttpContext.Session.GetJson<List<Evento>>("MiAgendaSesion");
                int totalEventos = agenda != null ? agenda.Count : 0;

                // Lógica de la Funcionalidad 3: Eventos Guardados (Me Interesa)
                var guardados = HttpContextAccessor.HttpContext.Session.GetJson<List<Evento>>("MisGuardadosSesion");
                int totalGuardados = guardados != null ? guardados.Count : 0;
            }

            <a asp-controller="Guardados" asp-action="Index" class="cart-link" title="Eventos Guardados" style="margin-right: 15px;">
                <i class="bi bi-bookmark-heart" style="font-size: 1.2rem;"></i>
                @if (totalGuardados > 0)
                {
                    <span class="cart-badge bg-primary">@totalGuardados</span>
                }
            </a>

            <a asp-controller="Agenda" asp-action="Index" class="cart-link" title="Ver mi agenda de eventos">
                <i class="bi bi-calendar-check" style="font-size: 1.2rem;"></i>
                @if (totalEventos > 0)
                {
                    <span class="cart-badge">@totalEventos</span>
                }
            </a>
    
            <a href="#">Iniciar Sesión</a>
            <button class="btn-registro">Registro</button>
        </div>
    </nav>

    <div class="contenido">
        @RenderBody()
    </div>

</body>
</html>