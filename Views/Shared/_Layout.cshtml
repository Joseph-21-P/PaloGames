<!DOCTYPE html>
@using Microsoft.AspNetCore.Http
@using PaloGames.Infrastructure
@using PaloGames.Models
@inject IHttpContextAccessor HttpContextAccessor
<html>
<head>
    <meta charset="utf-8" />
    <title>Nexus Gaming</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>

    <!-- HEADER -->
    <nav class="navbar">
        <div class="logo">
            <span>PALOGAMES</span>
        </div>

        <ul class="menu">
            <li><a href="#">Inicio</a></li>
            <li><a class="nav-link text-white" asp-area="" asp-controller="Juegos" asp-action="Index">Catálogo</a></li>
            <li><a href="#">Blog</a></li>
            <li><a href="#">Nosotros</a></li>
            <li><a href="#">Contacto</a></li>
        </ul>

        <div class="actions">
            @{
                // Recuperamos el carrito y sumamos las cantidades
                var cart = HttpContextAccessor.HttpContext.Session.GetJson<List<CartItem>>("Cart");
                int totalItems = cart != null ? cart.Sum(x => x.Cantidad) : 0;
            }

            <a asp-controller="Cart" asp-action="Index" class="cart-link" title="Ver mi carrito">
                <i class="bi bi-cart3"></i>
                @if (totalItems > 0)
                {
                    <span class="cart-badge">@totalItems</span>
                }
            </a>
    
            <a href="#">Iniciar Sesión</a>
            <button class="btn-registro">Registro</button>
        </div>
    </nav>

    <!-- CONTENIDO DE LAS VISTAS (IMPORTANTE) -->
    <div class="contenido">
        @RenderBody()
    </div>

</body>
</html>