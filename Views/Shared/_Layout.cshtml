<!DOCTYPE html>
@using Microsoft.AspNetCore.Http
@using PaloGames.Infrastructure
@using PaloGames.Models
@inject IHttpContextAccessor HttpContextAccessor
<html>
<head>
    <meta charset="utf-8" />
    <title>PALOEVENTS</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>

    <nav class="navbar">
        <a href="/Home" style="text-decoration: none;">
            <div class="logo">
                <span>PALOEVENTS</span>
            </div>
        </a>

        <ul class="menu">
            <li><a href="/Home">Inicio</a></li>
            <li><a class="nav-link text-dark" asp-area="" asp-controller="Eventos" asp-action="Index">Eventos</a></li>
            <li><a href="#">Blog</a></li>
            <li><a href="#">Nosotros</a></li>
            <li><a href="#">Contacto</a></li>
        </ul>

        <div class="actions">
            @{
                // Recuperamos el carrito y sumamos las cantidades
                var cart = HttpContextAccessor.HttpContext.Session.GetJson<List<CartItem>>("Cart");
                int totalItems = cart != null ? cart.Sum(x => x.Cantidad) : 0;
            }

            <a asp-controller="Cart" asp-action="Index" class="cart-link" title="Ver mi carrito">
                <i class="bi bi-cart3"></i>
                @if (totalItems > 0)
                {
                    <span class="cart-badge">@totalItems</span>
                }
            </a>
    
            <a href="#">Iniciar Sesión</a>
            <button class="btn-registro">Registro</button>
        </div>
    </nav>

    @{
        var ultimoMonto = HttpContextAccessor.HttpContext.Session.GetString("UltimoMonto");
    }
    @if (!string.IsNullOrEmpty(ultimoMonto))
    {
        <div style="background-color: #38b6ff; color: #0f172a; text-align: center; padding: 8px; font-weight: bold;">
            <a href="/Cart" style="color: #0f172a; text-decoration: none;">
                <i class="bi bi-clock-history"></i> Ver última solicitud: S/ @ultimoMonto
            </a>
        </div>
    }

    <div class="contenido">
        @RenderBody()
    </div>

</body>
</html>